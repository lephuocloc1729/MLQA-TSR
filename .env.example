# Local development
PYTHONPATH=.

# Qdrant text retrieval
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=traffic_law
QDRANT_API_KEY=

# Local/open-source VLM
MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
MODEL_TEMPERATURE=0.0
MODEL_MAX_NEW_TOKENS=512

# Optional external model provider. Leave blank for local-only experiments.
API_KEY=
BASE_URL=

# Optional cache location. Do not commit cache contents.
HF_HOME=.cache/huggingface
