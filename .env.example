# Local development
PYTHONPATH=.

# Qdrant text retrieval
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=traffic_law
QDRANT_API_KEY=

# Local/open-source VLM defaults
MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
MODEL_TEMPERATURE=0.0
MODEL_MAX_NEW_TOKENS=512

# Optional OpenAI-compatible VLM backend for non-mock benchmarks and live demo.
# Leave blank for mock smoke tests, retrieval-only demo, and cached prediction
# display. Store real secrets only in .env or shell environment variables.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
QWEN_VL_GPU_HOST=

# If Qwen2.5-VL-7B is unstable on the available GPU, rerun with:
# OPENAI_COMPATIBLE_MODEL=Qwen/Qwen2.5-VL-3B-Instruct
# and document the exact fallback reason in docs/experiments.md.

# Legacy optional external model provider placeholders. These remain blank
# unless a teammate wires an older provider-specific client.
API_KEY=
BASE_URL=

# Optional cache location. Do not commit cache contents.
HF_HOME=.cache/huggingface
